# ============================================================
# 网关环境变量配置
# 所有变量以 GATEWAY_ 为前缀，对应 gateway.yaml 中的配置项
# 格式: GATEWAY_{SECTION}_{KEY}，层级用 _ 分隔
# ============================================================

# --- 配置中心（可选，启用后从远程加载完整配置） ---
# GATEWAY_CONFIG_CENTER_TYPE=etcd
# GATEWAY_CONFIG_CENTER_ETCD_ENDPOINTS=127.0.0.1:2379
# GATEWAY_CONFIG_CENTER_ETCD_KEY=/gateway.yaml
# GATEWAY_CONFIG_CENTER_ETCD_TIMEOUT=5s
# GATEWAY_CONFIG_CENTER_ETCD_USERNAME=
# GATEWAY_CONFIG_CENTER_ETCD_PASSWORD=

# --- 服务器 ---
# GATEWAY_SERVER_LISTEN=:8082
# GATEWAY_SERVER_SHUTDOWN_TIMEOUT=30s

# --- 日志 ---
# GATEWAY_LOG_LEVEL=info
# GATEWAY_LOG_DEBUG=true

# --- 链路追踪 ---
# GATEWAY_TELEMETRY_ENABLED=true
# GATEWAY_TELEMETRY_SERVICE_NAME=gateway
# GATEWAY_TELEMETRY_EXPORTER_PROTOCOL=grpc
# GATEWAY_TELEMETRY_EXPORTER_ENDPOINT=localhost:4317

# --- 指标采集 ---
# GATEWAY_METRICS_ENABLED=true
# GATEWAY_METRICS_EXPORTER_PROTOCOL=grpc
# GATEWAY_METRICS_EXPORTER_ENDPOINT=localhost:4317

# --- 服务发现 ---
# GATEWAY_DISCOVERY_TYPE=static